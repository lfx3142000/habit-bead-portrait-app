<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_row_root"
    android:layout_width="match_parent"
    android:layout_height="32dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <ImageView
        android:id="@+id/widget_row_bead"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/widget_bead_description" />

    <TextView
        android:id="@+id/widget_row_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_row_value"
        android:layout_width="76dp"
        android:layout_height="24dp"
        android:gravity="end|center_vertical"
        android:paddingStart="8dp"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/widget_row_strip"
        android:layout_width="96dp"
        android:layout_height="22dp"
        android:contentDescription="@string/widget_weekly_strip_description"
        android:visibility="gone" />
</LinearLayout>
